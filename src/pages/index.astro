---
// Root page: detect browser language and redirect to /en/ or /zh/
// Falls back to /en/ for non-Chinese browsers.
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Ah Yeow Provision Supply</title>
    <!-- Fallback for JS-disabled browsers -->
    <meta http-equiv="refresh" content="0;url=/en/" />
  </head>
  <body>
    <script is:inline>
      (function () {
        var lang = (navigator.language || navigator.languages?.[0] || '').toLowerCase();
        if (lang.startsWith('zh')) {
          window.location.replace('/zh/');
        } else {
          window.location.replace('/en/');
        }
      })();
    </script>
  </body>
</html>
