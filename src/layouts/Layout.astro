---
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
  seo: {
    title: string;
    description: string;
    keywords: string;
  };
}

const { lang, seo } = Astro.props;

const selfHref = lang === 'en' ? '/en/' : '/zh/';
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-Hans-SG' : 'en-SG'}>
  <head>

    <script>
      const pwd = prompt("Enter password:");
      if (pwd === "loh") {
        // allowed, do nothing
      } else {
        history.length > 1 ? history.back() : window.location.replace("about:blank");
      }
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="icon" href="/logo.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="keywords" content={seo.keywords} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Ah Yeow Provision Supply" />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={`https://ahyeow.com.sg${selfHref}`} />
    <link rel="alternate" hreflang="en" href="https://ahyeow.com.sg/en/" />
    <link rel="alternate" hreflang="zh" href="https://ahyeow.com.sg/zh/" />
    <link rel="alternate" hreflang="x-default" href="https://ahyeow.com.sg/en/" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content={lang === 'zh' ? 'zh_SG' : 'en_SG'} />
    <meta property="og:locale:alternate" content={lang === 'zh' ? 'en_SG' : 'zh_SG'} />
    <meta property="og:site_name"   content="Ah Yeow Provision Supply" />
    <meta property="og:title"       content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image"       content="/logo.png" />
    <meta property="og:url"         content={`https://ahyeow.com.sg${selfHref}`} />

    <!-- Structured Data — LocalBusiness -->
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Ah Yeow Provision Supply",
      "alternateName": "亚耀土产供应",
      "description": "Singapore's trusted wholesale supplier of dried goods, rice, cooking oil, sugar, salt and Chinese provisions since 1994. Serving restaurants, coffee shops, caterers and hotel kitchens.",
      "telephone": "+6562832468",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "237 Serangoon Avenue 3, #01-120",
        "addressLocality": "Singapore",
        "postalCode": "550237",
        "addressCountry": "SG"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "05:30",
          "closes": "17:30"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Saturday","Sunday"],
          "opens": "05:30",
          "closes": "19:00"
        }
      ],
      "foundingDate": "1994",
      "taxID": "51897100K",
      "currenciesAccepted": "SGD",
      "priceRange": "$$",
      "hasMap": "https://maps.google.com/?q=237+Serangoon+Avenue+3+%2301-120+Singapore+550237",
      "sameAs": ["https://shopee.sg/_weixuannn1"]
    }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html, body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
