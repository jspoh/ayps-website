---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['clients'];
}

const { t } = Astro.props;

const clientPlaceholders = Array.from({ length: 12 }, (_, i) => i + 1);
---

<section id="clients" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <p class="text-red-700 font-bold text-sm uppercase tracking-widest mb-3">{t.sectionLabel}</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-4">{t.heading}</h2>
      <p class="text-zinc-500 text-lg max-w-2xl mx-auto">{t.subheading}</p>
    </div>

    <!-- Client logo grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-16">
      {clientPlaceholders.map(n => (
        <div class="group aspect-[3/2] bg-stone-50 border border-stone-200 rounded-xl flex flex-col items-center justify-center gap-1 hover:border-red-200 hover:bg-red-50 transition-all duration-300 cursor-default p-3">
          <!-- Replace with <img> once you have client logos -->
          <div class="text-stone-300 text-xs font-semibold text-center leading-tight">Client Logo {n}</div>
        </div>
      ))}
    </div>

    <!-- Sector strip -->
    <div class="border-t border-stone-100 pt-12">
      <p class="text-center text-zinc-500 text-sm uppercase tracking-widest font-semibold mb-8">
        {t.sectorLabel}
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        {t.sectors.map(s => (
          <div class="flex flex-col items-center gap-2 text-center">
            <span class="text-3xl">{s.icon}</span>
            <span class="text-zinc-600 text-sm font-medium">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
