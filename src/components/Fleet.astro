---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['fleet'];
}

const { t } = Astro.props;

const featureIcons = [
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
];
---

<section id="fleet" class="py-20 bg-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <p class="text-amber-400 font-bold text-sm uppercase tracking-widest mb-3">{t.sectionLabel}</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
        {t.heading}<br />
        <span class="text-amber-400">{t.headingAccent}</span>
      </h2>
      <p class="text-zinc-400 text-lg max-w-2xl mx-auto">{t.subheading}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center mb-16">

      <!-- Fleet image placeholder -->
      <div>
        <div class="aspect-16/10 bg-zinc-800 border-2 border-dashed border-zinc-600 rounded-2xl flex items-center justify-center text-zinc-500 text-sm font-medium">
          [ Delivery Fleet Photo ]
        </div>
        <div class="grid grid-cols-4 gap-3 mt-4">
          {t.stats.map(s => (
            <div class="bg-zinc-800 rounded-lg p-3 text-center">
              <div class="text-amber-400 font-extrabold text-base leading-tight">{s.value}</div>
              <div class="text-zinc-400 text-xs mt-1">{s.label}</div>
            </div>
          ))}
        </div>
        <p class="text-zinc-600 text-xs mt-2">{t.footNote}</p>
      </div>

      <!-- Features list -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {t.features.map((f, i) => (
          <div class="flex gap-4 items-start group">
            <div class="shrink-0 w-12 h-12 rounded-xl bg-red-900/50 border border-red-800/50 flex items-center justify-center text-amber-400 group-hover:bg-red-900 transition-colors duration-300"
                 set:html={featureIcons[i]} />
            <div>
              <h3 class="text-white font-semibold mb-1">{f.title}</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <div class="text-center border-t border-zinc-800 pt-10">
      <p class="text-zinc-400 mb-5 text-base">{t.ctaNote}</p>
      <a href="#contact"
         class="inline-block bg-amber-500 hover:bg-amber-400 text-white px-9 py-3 rounded-lg font-bold transition-colors duration-200 shadow-lg">
        {t.cta}
      </a>
    </div>

  </div>
</section>
