---

<section id="products" class="py-20 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <p class="text-red-700 font-bold text-sm uppercase tracking-widest mb-3">What We Carry</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-4">
        Our Product Categories
      </h2>
      <p class="text-zinc-500 text-lg max-w-2xl mx-auto">
        Wholesale provisions for restaurants, coffee shops, hawker stalls and caterers.
        Over 1,000 products — from bulk rice and dried seafood to spices, sauces and soup ingredients.
      </p>
    </div>

    <!-- Product grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {categories.map(cat => (
        <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow duration-300 border border-stone-100 group">
          <div class="text-red-800 mb-4 group-hover:text-amber-600 transition-colors duration-300"
               set:html={cat.icon} />
          <h3 class="font-bold text-zinc-900 text-base mb-2">{cat.title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{cat.desc}</p>
        </div>
      ))}
    </div>

    <!-- CTA strip -->
    <div class="mt-12 text-center">
      <p class="text-zinc-500 mb-4">Don't see what you're looking for? We likely have it in stock.</p>
      <a href="#contact"
         class="inline-block border-2 border-red-800 text-red-800 hover:bg-red-800 hover:text-white px-8 py-3 rounded-lg font-semibold transition-all duration-200">
        Ask About Specific Products
      </a>
    </div>

  </div>
</section>
