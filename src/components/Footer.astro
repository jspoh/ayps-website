---
const navLinks = [
  { label: "About Us",     href: "#about" },
  { label: "Products",     href: "#products" },
  { label: "Our Clients",  href: "#clients" },
  { label: "Delivery",     href: "#fleet" },
  { label: "Testimonials", href: "#testimonials" },
  { label: "Contact",      href: "#contact" },
];
---

<footer class="bg-red-950 text-white">

  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <img src="/logo.png" alt="Ah Yeow Provision Supply" class="h-12 w-auto" />
          <div class="leading-tight">
            <div class="font-bold text-base text-white">亚耀土产供应</div>
            <div class="text-red-300 text-xs tracking-wider uppercase">Provision Supply</div>
          </div>
        </div>
        <p class="text-red-200 text-sm leading-relaxed max-w-xs">
          Singapore's trusted wholesale supplier of Chinese dried goods,
          traditional provisions, and specialty food products since 1994.
        </p>
        <div class="mt-6">
          <p class="text-red-300 text-xs uppercase tracking-widest font-semibold mb-3">UEN</p>
          <p class="text-red-200 text-sm font-mono">51897100K</p>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-5">Quick Links</h4>
        <ul class="space-y-2.5">
          {navLinks.map(link => (
            <li>
              <a href={link.href}
                 class="text-red-200 hover:text-amber-400 text-sm transition-colors duration-200 flex items-center gap-1.5">
                <span class="text-red-600">›</span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-5">Find Us</h4>
        <div class="space-y-4">
          <div class="flex gap-3 text-sm">
            <svg class="w-4 h-4 text-amber-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <address class="text-red-200 not-italic leading-relaxed">
              237 Serangoon Avenue 3<br />
              #01-120<br />
              Singapore 550237
            </address>
          </div>
          <div class="flex gap-3 text-sm items-center">
            <svg class="w-4 h-4 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:+6562832468" class="text-red-200 hover:text-amber-400 transition-colors">6283 2468</a>
          </div>
          <div class="flex gap-3 text-sm items-start">
            <svg class="w-4 h-4 text-amber-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div class="text-red-200 leading-relaxed">
              Mon–Fri: 5:30 am – 5:30 pm<br />
              Sat–Sun: 5:30 am – 7:00 pm
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-red-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-red-400 text-xs">
        © {new Date().getFullYear()} Ah Yeow Provision Supply. All rights reserved.
      </p>
      <p class="text-red-500 text-xs">
        237 Serangoon Avenue 3, #01-120, Singapore 550237
      </p>
    </div>
  </div>

</footer>
