---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['products'];
}

const { t } = Astro.props;

const icons = [
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7h16M4 12h16M4 17h7"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-2-2m0 0l-2 2m2-2v10a2 2 0 01-2 2H8a2 2 0 01-2-2V5a2 2 0 012-2h8l2 2z"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h8M12 8v8"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h18v4H3zM3 7v13a1 1 0 001 1h16a1 1 0 001-1V7"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 11h6"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.701 2.701 0 00-1.5-.454M9 6l3 3m0 0l3-3m-3 3V2"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>`,
];
---

<section id="products" class="py-20 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <p class="text-red-700 font-bold text-sm uppercase tracking-widest mb-3">{t.sectionLabel}</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-4">{t.heading}</h2>
      <p class="text-zinc-500 text-lg max-w-2xl mx-auto">{t.subheading}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {t.categories.map((cat, i) => (
        <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow duration-300 border border-stone-100 group">
          <div class="text-red-800 mb-4 group-hover:text-amber-600 transition-colors duration-300"
               set:html={icons[i]} />
          <h3 class="font-bold text-zinc-900 text-base mb-2">{cat.title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{cat.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-zinc-500 mb-4">{t.ctaNote}</p>
      <a href="#contact"
         class="inline-block border-2 border-red-800 text-red-800 hover:bg-red-800 hover:text-white px-8 py-3 rounded-lg font-semibold transition-all duration-200">
        {t.cta}
      </a>
    </div>

  </div>
</section>
