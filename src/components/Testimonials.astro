---
// Replace these with real testimonials when you collect them.
const testimonials = [
  {
    quote: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ah Yeow has been our go-to supplier for dried seafood and preserved goods for years. The quality is consistently excellent and delivery is always on time.",
    name: "Lorem Ipsum",
    title: "Head Chef",
    company: "Restaurant / Hotel Name",
    rating: 5,
  },
  {
    quote: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. We've tried other suppliers but none can match the range and quality of specialty Chinese products that Ah Yeow carries. Their team is knowledgeable and always helpful.",
    name: "Lorem Ipsum",
    title: "Owner",
    company: "F&B Business Name",
    rating: 5,
  },
  {
    quote: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. As a catering company handling large events, reliability is everything. Ah Yeow has never let us down — orders are accurate, deliveries are punctual, and the pricing is fair.",
    name: "Lorem Ipsum",
    title: "Operations Manager",
    company: "Catering Company Name",
    rating: 5,
  },
];
---

<section id="testimonials" class="py-20 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <p class="text-red-700 font-bold text-sm uppercase tracking-widest mb-3">What Our Clients Say</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-4">
        Testimonials
      </h2>
      <p class="text-zinc-500 text-lg max-w-xl mx-auto">
        Don't just take our word for it — here's what Singapore's top kitchens have to say.
      </p>
    </div>

    <!-- Testimonial cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map(t => (
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-stone-100 flex flex-col">
          <!-- Quote mark -->
          <svg class="w-10 h-10 text-red-800/20 mb-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>

          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote text -->
          <p class="text-zinc-600 text-sm leading-relaxed mb-6 flex-grow italic">
            "{t.quote}"
          </p>

          <!-- Reviewer -->
          <div class="flex items-center gap-3 pt-4 border-t border-stone-100">
            <!-- ============================================================
                 PLACEHOLDER: Replace with reviewer's photo if available.
                 e.g. <img src="/testimonials/reviewer.jpg" alt="..." class="w-10 h-10 rounded-full object-cover" />
            ============================================================ -->
            <div class="w-10 h-10 rounded-full bg-red-100 border border-red-200 flex items-center justify-center text-red-700 font-bold text-sm flex-shrink-0">
              {t.name.charAt(0)}
            </div>
            <div>
              <div class="font-semibold text-zinc-900 text-sm">{t.name}</div>
              <div class="text-zinc-400 text-xs">{t.title}, {t.company}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
