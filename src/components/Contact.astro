---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['contact'];
}

const { t } = Astro.props;

const times = ['5:30 am – 5:30 pm', '5:30 am – 5:30 pm', '5:30 am – 5:30 pm', '5:30 am – 5:30 pm', '5:30 am – 5:30 pm', '5:30 am – 7:00 pm', '5:30 am – 7:00 pm'];

const todayIndex = new Date().getDay(); // 0=Sun,1=Mon...6=Sat — reorder to match our days array (Mon=0)
const todayLocal = todayIndex === 0 ? 6 : todayIndex - 1;
---

<section id="contact" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <p class="text-red-700 font-bold text-sm uppercase tracking-widest mb-3">{t.sectionLabel}</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-4">{t.heading}</h2>
      <p class="text-zinc-500 text-lg max-w-xl mx-auto">{t.subheading}</p>
    </div>

    <div class="grid lg:grid-cols-5 gap-12">

      <!-- Left: contact info + map -->
      <div class="lg:col-span-2 flex flex-col gap-8">

        <div>
          <h3 class="text-zinc-900 font-bold text-lg mb-4">{t.visitUs}</h3>
          <div class="flex gap-3 mb-4">
            <svg class="w-5 h-5 text-red-700 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div>
              <p class="text-zinc-800 font-medium">237 Serangoon Avenue 3</p>
              <p class="text-zinc-600">#01-120</p>
              <p class="text-zinc-600">Singapore 550237</p>
            </div>
          </div>
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-red-700 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:+6562832468" class="text-zinc-800 font-medium hover:text-red-700 transition-colors">6283 2468</a>
          </div>
        </div>

        <div>
          <h3 class="text-zinc-900 font-bold text-lg mb-4">{t.openingHours}</h3>
          <div class="space-y-1.5">
            {t.days.map((day, i) => (
              <div class={`flex justify-between text-sm py-1 ${i === todayLocal ? 'text-red-700 font-semibold' : 'text-zinc-600'}`}>
                <span>{day}</span>
                <span>{times[i]}</span>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h3 class="text-zinc-900 font-bold text-lg mb-4">{t.findUs}</h3>
          <div class="rounded-xl overflow-hidden border border-stone-200 shadow-sm">
            <iframe
              title="Ah Yeow Provision Supply location"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3988.6898985697517!2d103.87297!3d1.35413!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31da17e1a0c0a0a1%3A0x0!2s237+Serangoon+Ave+3%2C+%2301-120%2C+Singapore+550237!5e0!3m2!1sen!2ssg!4v1700000000000"
              width="100%"
              height="240"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full">
            </iframe>
          </div>
          <a href="https://maps.google.com/?q=237+Serangoon+Ave+3+%2301-120+Singapore+550237"
             target="_blank"
             rel="noopener noreferrer"
             class="inline-flex items-center gap-1.5 text-red-700 hover:text-red-600 text-sm font-medium mt-2 transition-colors">
            {t.openInMaps}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>

      </div>

      <!-- Right: contact form -->
      <div class="lg:col-span-3">
        <div class="bg-stone-50 rounded-2xl p-8 border border-stone-100">
          <h3 class="text-zinc-900 font-bold text-xl mb-6">{t.sendEnquiry}</h3>

          <form id="contact-form" class="space-y-5">

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold text-zinc-700 mb-1.5" for="cf-name">
                  {t.nameLabel} <span class="text-red-600">*</span>
                </label>
                <input id="cf-name" name="name" type="text" required
                  placeholder={t.namePlaceholder}
                  class="w-full border border-stone-200 rounded-lg px-4 py-2.5 text-sm text-zinc-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-700 focus:border-transparent transition" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-zinc-700 mb-1.5" for="cf-company">
                  {t.companyLabel}
                </label>
                <input id="cf-company" name="company" type="text"
                  placeholder={t.companyPlaceholder}
                  class="w-full border border-stone-200 rounded-lg px-4 py-2.5 text-sm text-zinc-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-700 focus:border-transparent transition" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold text-zinc-700 mb-1.5" for="cf-email">
                  {t.emailLabel} <span class="text-red-600">*</span>
                </label>
                <input id="cf-email" name="email" type="email" required
                  placeholder="you@example.com"
                  class="w-full border border-stone-200 rounded-lg px-4 py-2.5 text-sm text-zinc-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-700 focus:border-transparent transition" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-zinc-700 mb-1.5" for="cf-phone">
                  {t.phoneLabel}
                </label>
                <input id="cf-phone" name="phone" type="tel"
                  placeholder="+65 XXXX XXXX"
                  class="w-full border border-stone-200 rounded-lg px-4 py-2.5 text-sm text-zinc-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-700 focus:border-transparent transition" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-zinc-700 mb-1.5" for="cf-inquiry">
                {t.inquiryLabel} <span class="text-red-600">*</span>
              </label>
              <select id="cf-inquiry" name="inquiryType" required
                class="w-full border border-stone-200 rounded-lg px-4 py-2.5 text-sm text-zinc-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-700 focus:border-transparent transition appearance-none">
                <option value="" disabled selected>{t.inquiryPlaceholder}</option>
                {t.inquiryOptions.map(opt => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-zinc-700 mb-1.5" for="cf-message">
                {t.messageLabel} <span class="text-red-600">*</span>
              </label>
              <textarea id="cf-message" name="message" required rows="5"
                placeholder={t.messagePlaceholder}
                class="w-full border border-stone-200 rounded-lg px-4 py-2.5 text-sm text-zinc-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-700 focus:border-transparent transition resize-none">
              </textarea>
            </div>

            <div id="cf-success" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm font-medium"
                 data-msg={t.successMsg}>
              {t.successMsg}
            </div>
            <div id="cf-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm font-medium"
                 data-msg={t.errorMsg}>
              {t.errorMsg}
            </div>

            <button type="submit" id="cf-submit"
              class="w-full bg-red-800 hover:bg-red-700 disabled:opacity-60 disabled:cursor-not-allowed text-white font-bold py-3 px-6 rounded-lg transition-colors duration-200 flex items-center justify-center gap-2">
              <span id="cf-btn-text" data-default={t.submitBtn} data-sending={t.sendingBtn}>{t.submitBtn}</span>
              <svg id="cf-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </button>

          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const submit  = document.getElementById('cf-submit')   as HTMLButtonElement | null;
  const btnText = document.getElementById('cf-btn-text') as HTMLElement | null;
  const spinner = document.getElementById('cf-spinner');
  const success = document.getElementById('cf-success');
  const error   = document.getElementById('cf-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submit) return;

    submit.disabled = true;
    if (btnText) btnText.textContent = btnText.dataset.sending ?? 'Sending…';
    spinner?.classList.remove('hidden');
    success?.classList.add('hidden');
    error?.classList.add('hidden');

    const payload = {
      name:        (form.elements.namedItem('name')        as HTMLInputElement).value,
      company:     (form.elements.namedItem('company')     as HTMLInputElement).value,
      email:       (form.elements.namedItem('email')       as HTMLInputElement).value,
      phone:       (form.elements.namedItem('phone')       as HTMLInputElement).value,
      inquiryType: (form.elements.namedItem('inquiryType') as HTMLSelectElement).value,
      message:     (form.elements.namedItem('message')     as HTMLTextAreaElement).value,
    };

    try {
      const res  = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      const data = await res.json();
      if (res.ok && data.success) { success?.classList.remove('hidden'); form.reset(); }
      else { error?.classList.remove('hidden'); }
    } catch {
      error?.classList.remove('hidden');
    } finally {
      submit.disabled = false;
      if (btnText) btnText.textContent = btnText.dataset.default ?? 'Send Enquiry';
      spinner?.classList.add('hidden');
    }
  });
</script>
