---
const categories = [
  {
    title: "Dried Seafood",
    desc: "Scallops, prawns, abalone, fish maw, sea cucumber, dried squid and more — sourced from trusted suppliers.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-2-2m0 0l-2 2m2-2v10a2 2 0 01-2 2H8a2 2 0 01-2-2V5a2 2 0 012-2h8l2 2z"/></svg>`,
  },
  {
    title: "Mushrooms & Fungi",
    desc: "Shiitake, black fungus, white fungus, dried lily buds, cloud ear and other premium dried mushrooms.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h8M12 8v8"/></svg>`,
  },
  {
    title: "Chinese Preserved Foods",
    desc: "Salted fish (咸鱼), preserved vegetables (梅菜), fermented bean curd, dried tofu skin and classic pantry staples.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h18v4H3zM3 7v13a1 1 0 001 1h16a1 1 0 001-1V7"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 11h6"/></svg>`,
  },
  {
    title: "Traditional Snacks & Tidbits",
    desc: "Old-school biscuits, peanut candy, haw flakes, ti-bo (dried whitebait), preserved plums and nostalgic treats.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.701 2.701 0 00-1.5-.454M9 6l3 3m0 0l3-3m-3 3V2"/></svg>`,
  },
  {
    title: "Rice, Grains & Legumes",
    desc: "Fragrant jasmine rice, glutinous rice, red beans, mung beans, barley, lotus seeds and dried longan.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7h16M4 12h16M4 17h7"/></svg>`,
  },
  {
    title: "Condiments & Sauces",
    desc: "Oyster sauce, dark soy, fish sauce, sesame oil, fermented black bean paste and specialty Chinese condiments.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: "Herbs & Traditional Medicine",
    desc: "Wolfberries (枸杞), red dates, dang gui, astragalus, dried herbs for soups and Traditional Chinese Medicine.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>`,
  },
  {
    title: "Seasonal & Festive",
    desc: "Chinese New Year goodies, mooncake ingredients, Dumpling Festival supplies, and festive provisions year-round.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>`,
  },
];
---

<section id="products" class="py-20 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <p class="text-red-700 font-bold text-sm uppercase tracking-widest mb-3">What We Carry</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-4">
        Our Product Categories
      </h2>
      <p class="text-zinc-500 text-lg max-w-2xl mx-auto">
        Over 1,000 products spanning the full range of Chinese provisions — from everyday staples
        to hard-to-find specialty items.
      </p>
    </div>

    <!-- Product grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {categories.map(cat => (
        <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow duration-300 border border-stone-100 group">
          <div class="text-red-800 mb-4 group-hover:text-amber-600 transition-colors duration-300"
               set:html={cat.icon} />
          <h3 class="font-bold text-zinc-900 text-base mb-2">{cat.title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{cat.desc}</p>
        </div>
      ))}
    </div>

    <!-- CTA strip -->
    <div class="mt-12 text-center">
      <p class="text-zinc-500 mb-4">Don't see what you're looking for? We likely have it in stock.</p>
      <a href="#contact"
         class="inline-block border-2 border-red-800 text-red-800 hover:bg-red-800 hover:text-white px-8 py-3 rounded-lg font-semibold transition-all duration-200">
        Ask About Specific Products
      </a>
    </div>

  </div>
</section>
